# ============================================
# SCAN SOL BOT - Configuration (Template)
# ============================================

# Solana RPC Pool (Comma-separated URLs)
SOLANA_RPC_URLS=your_rpc_url_1,your_rpc_url_2
SOLANA_WS_URL=your_ws_url

# Wallet Private Key (Base58)
WALLET_PRIVATE_KEY=your_private_key_here

# Helius Execution Pipeline
HELIUS_EXECUTION_RPC_URL=
HELIUS_SENDER_URL=

# Jito Configuration
JITO_ENABLED=true
JITO_TIP_AMOUNT=0.001
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_ACCOUNTS=4ACfpUFoaSD9bfPdeu6DBt89gB6ENTeHBXCAi87NhDEE,D2L6yPZ2FmmmTKPgzaMKdhu6EWZcTpLy1Vhx8uvZe7NZ,9bnz4RShgq1hAnLnZbP8kbgBg1kEmcJBYQq3gQbmnSta

# Telegram Settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Bot Settings
AUTO_BUY_ENABLED=false
AUTO_SELL_ENABLED=true
BUY_AMOUNT_SOL=0.1
MAX_CONCURRENT_POSITIONS=5
DAILY_LOSS_LIMIT_SOL=2.0

# Slippage (%)
BUY_SLIPPAGE=15
SELL_SLIPPAGE=20

# Take Profit / Stop Loss
TAKE_PROFIT_PERCENT=100
STOP_LOSS_PERCENT=50

# Monitoring Rules
EARLY_BUYERS_TO_MONITOR=5
GLOBAL_FEE_THRESHOLD=0.5

# Performance Tuning
RPC_MAX_PER_ENDPOINT=2
RPC_MIN_SPACING_MS=500
MAX_CONCURRENT_ANALYSIS=3

# Logging
LOG_LEVEL=info
